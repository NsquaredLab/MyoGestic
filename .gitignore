# logs scratch
/tmp/myogestic-logs/

# Local VHI install — populated by `python -m myogestic.tools.install_vhi`
# (release binary) or symlinked to a VHI source checkout (Godot project).
# virtual_hand() defaults to this path; override with $VHI_PATH.
tools/MyoGestic-VHI

# Browser playground - locally built MyoGestic wheel + manifest.
# CI generates both fresh each deploy; committing would just bitrot.
docs/playground/wheels/*.whl
docs/playground/wheels/manifest.json
